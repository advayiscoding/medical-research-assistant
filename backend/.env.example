# Copy to .env for local development. Every setting in app/core/config.py
# can be overridden here. NEVER commit a real .env.

ENVIRONMENT=dev
LOG_LEVEL=INFO

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://medresearch:medresearch@localhost:5432/medresearch

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-secret-do-not-use-in-prod

# Claude API — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Embeddings (optional override; biomedical: NeuML/pubmedbert-base-embeddings)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ChromaDB — leave CHROMA_HOST unset for embedded local mode
# CHROMA_HOST=localhost
# CHROMA_PORT=8001

# PubMed (both optional; API key raises rate limit 3 -> 10 req/s)
PUBMED_API_KEY=
PUBMED_EMAIL=
