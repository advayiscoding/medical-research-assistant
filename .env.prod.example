# Production environment template (Azure). Copy the KEYS into Azure Key Vault
# and reference them from the Container App; do NOT put real values in any file
# that could be committed. This template documents every variable prod needs.

# --- Application ---
ENVIRONMENT=prod                       # enables JSON logs; enforces JWT_SECRET is set
LOG_LEVEL=INFO
# Real frontend origin(s) — NOT localhost. JSON array.
CORS_ORIGINS=["https://<frontend-fqdn>"]

# --- Secrets (Key Vault → secretref) ---
JWT_SECRET=<keyvault:jwt-secret>       # 48+ random bytes; boot fails if left as dev default
ANTHROPIC_API_KEY=<keyvault:anthropic-key>
# Managed Postgres connection (password from Key Vault, sslmode required)
DATABASE_URL=postgresql+asyncpg://medresearch:<keyvault:pg-password>@<pg-host>:5432/medresearch

# --- ChromaDB (internal Container App) ---
CHROMA_HOST=chromadb                   # internal ingress hostname
CHROMA_PORT=8000

# --- Model config ---
CLAUDE_MODEL=claude-sonnet-5
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2  # or NeuML/pubmedbert-base-embeddings

# --- PubMed (optional; API key raises rate limit 3 -> 10 req/s) ---
PUBMED_EMAIL=<contact-email>
PUBMED_API_KEY=<keyvault:pubmed-key>

# --- Frontend build arg (set at image build time, not runtime) ---
# NEXT_PUBLIC_API_URL=https://<backend-fqdn>/api
